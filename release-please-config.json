{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",

  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "jira",
      "components": ["jira-core", "jira-commands"]
    }
  ],

  "packages": {
    "crates/jira-core": {
      "release-type": "rust",
      "component": "jira-core",
      "changelog-path": "../../CHANGELOG.md"
    },
    "crates/jira": {
      "release-type": "rust",
      "component": "jira-commands",
      "changelog-path": "../../CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "plugin/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
